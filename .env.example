# ── Software Factory — Environment Configuration ──
# Copy this file to .env and fill in your API keys.
# At least ONE LLM provider is required for agents to work.
# Without any key, set PLATFORM_LLM_PROVIDER=demo for mock mode.

# ── LLM Provider (choose one as primary) ──
# Options: minimax, azure-openai, azure-ai, nvidia, demo
PLATFORM_LLM_PROVIDER=demo
# PLATFORM_LLM_MODEL=           # Override default model (optional)

# ── MiniMax (free tier available — https://www.minimaxi.com) ──
# MINIMAX_API_KEY=your-key-here

# ── Azure OpenAI (https://portal.azure.com) ──
# AZURE_OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# ── Azure AI Foundry (https://ai.azure.com) ──
# AZURE_AI_API_KEY=your-key-here
# AZURE_AI_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com

# ── NVIDIA NIM (https://build.nvidia.com) ──
# NVIDIA_API_KEY=nvapi-your-key-here

# ── Authentication ──
# Legacy API key for internal tooling / marathon watcher (Bearer token)
# Leave unset in production and use proper JWT login instead.
# MACARON_API_KEY=your-internal-key

# ── Rate Limiting ──
# LLM_RATE_LIMIT_RPM=15         # Max requests per minute (default: 15)

# ── Auto-Heal ──
# AUTOHEAL_ENABLED=1             # Enable auto-heal loop (default: 1)
# AUTOHEAL_INTERVAL=60           # Scan interval in seconds (default: 60)

# ── Workspace ──
# WORKSPACE_ROOT=/app/workspace  # Project workspace root (auto-created per project)

# ── Project Registry ──
# SF_LOCAL=1                      # Set to load your own projects instead of demo projects

# ── Integrations (optional) ──
# JIRA_URL=https://your-jira-instance/jira
# JIRA_PROJECT=YOUR_PROJECT_KEY
# JIRA_TOKEN=your-jira-pat-or-api-token
# CONFLUENCE_URL=https://your-confluence-instance/confluence
# CONFLUENCE_SPACE=YOUR_SPACE_KEY
# CONFLUENCE_SPACE_KEY=YOUR_SPACE_KEY
# CONFLUENCE_HOMEPAGE_ID=your-homepage-page-id
# CONFLUENCE_TOKEN=your-confluence-pat
# GITLAB_URL=https://your-gitlab-instance
# GITLAB_TOKEN=your-gitlab-pat
# ATLASSIAN_TOKEN=your-token
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# GITHUB_WEBHOOK_SECRET=your-secret

# ── OAuth Login (optional) ──
# GITHUB_CLIENT_ID=your-github-oauth-app-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
# AZURE_AD_CLIENT_ID=your-azure-app-registration-client-id
# AZURE_AD_CLIENT_SECRET=your-azure-app-registration-client-secret
# AZURE_AD_TENANT_ID=your-azure-tenant-id   # or 'common' for multi-tenant

# ── Production Infrastructure (never commit real values) ──
# SF_NODE1_IP=<azure-sf-node1-private-ip>
# SF_NODE2_IP=<azure-sf-node2-public-ip>
# SF_NODE3_IP=<azure-sf-node3-private-ip>
# AZURE_VM_IP=<azure-demo-vm-public-ip>
# AZURE_VM_USER=azureadmin
# AZ_NODE2_SSH_HOST=sfadmin@<node2-ip>
# OVH_IP=<ovh-demo-public-ip>

# ── Demo Login ──
# SF_DEMO_EMAIL=admin@demo.local
# SF_DEMO_PASSWORD=your-demo-password

# ── Project Paths ──
# SF_ROOT=/path/to/software-factory
# MF_ROOT=/path/to/migration-factory

# ── Analytics (optional) ──
# External analytics script domain — added to CSP script-src when set
# PLATFORM_ANALYTICS_URL=https://analytics.example.com
