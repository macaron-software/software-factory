# Dashboard - Environment Variables Template

# Server Configuration
DASHBOARD_PORT=8080
DASHBOARD_HOST=127.0.0.1
DASHBOARD_DEBUG=false
DASHBOARD_LOG_LEVEL=warning

# Database
DASHBOARD_DB_PATH=./data/factory.db

# Azure Production Environment
AZURE_PLATFORM_URL=https://your-azure-instance.com
AZURE_SSH_HOST=your-azure-vm.com
AZURE_SSH_USER=macaron

# OVH Demo Environment
OVH_PLATFORM_URL=https://your-ovh-instance.com
OVH_SSH_HOST=your-ovh-server.com
OVH_SSH_USER=debian

# RTK Integration (optional)
RTK_DB_PATH=~/.local/share/rtk/history.db
